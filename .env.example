# ============================================================================
# משתני סביבה לפריסת ההאב — העתק ל-.env (מקומי) או הזרק ל-Railway Variables.
# מקור: process.env בקוד ה-api-server. סמן ✅ מה שבאמת בשימוש אצלך.
# ============================================================================

# ---- חובה ----
DATABASE_URL=                 # Postgres. ב-Railway נוצר אוטומטית ע"י תוסף Postgres
SESSION_SECRET=               # מחרוזת אקראית ארוכה (openssl rand -hex 32)
APP_BASE_URL=                 # כתובת ההאב באוויר, למשל https://hub.yourdomain.com
# PORT / BASE_PATH — מוזרקים אוטומטית בקונטיינר (Caddi/בנייה). אל תגדיר ידנית בפרוד.

# ---- שערי גישה (אם בשימוש) ----
APP_ACCESS_PASSWORD=          # סיסמת כניסה לאפליקציה
AOR_ACCESS_PASSWORD=          # סיסמת גישה משנית

# ---- מייל (בחר אחד) ----
RESEND_API_KEY=               # Resend (מומלץ)
RESEND_FROM=                  # כתובת שולח מאומתת ב-Resend
# חלופת SMTP (היה ב-.replit): SMTP_USER / SMTP_FROM / סיסמה

# ---- טלגרם (אם בשימוש) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ADMIN_TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# ---- וואטסאפ (אם בשימוש) ----
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_LINK=

# ---- AI / מודלים (אם בשימוש) ----
OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=
GROQ_API_KEY=
OLLAMA_BASE_URL=
OLLAMA_MODEL=

# ---- שונות ----
INTAKE_FORM_URL=
LOG_LEVEL=info
WEBHOOK_DEDUP_WINDOW_SECONDS=
WEBHOOK_DEDUP_WINDOW_HOURS=
WEBHOOK_DEDUP_WINDOW_DAYS=
WEBHOOK_DEDUP_WARN_THRESHOLD=

# ============================================================================
# ⚠️ Google Sheets: בקוד ה-api-server האינטגרציה עוברת דרך @replit/connectors-sdk
# (Replit-only) ולא תעבוד מחוץ ל-Replit. צריך להחליף ל-Google Service Account:
#   GOOGLE_SERVICE_ACCOUNT_JSON=   (או GOOGLE_APPLICATION_CREDENTIALS)
# זהו שלב 2 בתוכנית הפריסה.
# ============================================================================
